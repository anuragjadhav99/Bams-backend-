# ── Database ───────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/?appName=BAMS

# ── JWT Secrets ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── Google OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AWS S3 ─────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=bams-notes-private

# ── Razorpay ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── SMTP (optional — email features disabled if not set) ───────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bamsnotes.in

# ── App Config (optional — defaults shown) ─────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
